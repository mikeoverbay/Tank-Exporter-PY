# ---------------------------------------------------------------------------
gun_iii_scan.txt
gun_iii_triple_scan.txt
gun_iii_unique_tuples.txt
gun_material_fx_scan.txt
gun_vertex_blend_scan.txt
gun_palette_table.txt
